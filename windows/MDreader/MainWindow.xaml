<Window
    x:Class="MDreader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MDreader">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left sidebar: library / outline -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="4" Padding="8,8,8,4">
                <ToggleButton x:Name="LibTab" Content="库" IsChecked="True" Click="OnTabToggle" />
                <ToggleButton x:Name="OutlineTab" Content="大纲" Click="OnTabToggle" />
                <ToggleButton x:Name="FavFilter" Content="&#x2605;" Click="OnFavFilter" ToolTipService.ToolTip="仅看收藏" />
            </StackPanel>
            <TextBox x:Name="SearchBox" Grid.Row="1" Margin="8,0,8,4" PlaceholderText="搜索标题…" TextChanged="OnSearch" />
            <Grid Grid.Row="2">
                <ListView
                    x:Name="DocList"
                    IsItemClickEnabled="True"
                    ItemClick="OnDocClick"
                    RightTapped="OnDocRightTapped">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="0,4">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Subtitle}" Opacity="0.6" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding BucketTitle}" FontWeight="Bold" Padding="12,8,0,2" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                </ListView>
                <ListView
                    x:Name="OutlineList"
                    Visibility="Collapsed"
                    IsItemClickEnabled="True"
                    ItemClick="OnOutlineClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" Margin="{Binding Indent}" Padding="12,2" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" />

        <!-- Right: toolbar + reader -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="4" Padding="8,6" Background="{ThemeResource AppBarBackground}">
                <Button Click="OnZoomOut" Content="&#x2212;" Width="32">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Subtract" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                </Button>
                <TextBlock x:Name="ZoomLabel" VerticalAlignment="Center" Width="48" TextAlignment="Center" Text="100%" />
                <Button Click="OnZoomIn" Content="+" Width="32">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Add" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Click="OnZoomReset" Content="重置" />
                <Border Width="8" />
                <Button Click="OnRefresh" Content="刷新" ToolTipService.ToolTip="从源文件重新读取" />
                <Button Click="OnOpenEditor" Content="编辑" ToolTipService.ToolTip="外部编辑器打开源文件" />
                <Button Click="OnExportPdf" Content="PDF" ToolTipService.ToolTip="导出 PDF" />
                <Border Width="8" />
                <Button Click="OnAbout" Content="关于" />
            </StackPanel>
            <WebView2 x:Name="WebView" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
